"""Kafka stream processor for real-time fraud detection."""
import json
from confluent_kafka import Consumer, Producer, KafkaError
from app.core.config import get_settings
from app.core.logging import get_logger
from app.models.schemas import Transaction
from app.services.model_service import model_service

logger = get_logger(__name__)
settings = get_settings()


class FraudStreamProcessor:
    def __init__(self):
        self.consumer = None
        self.producer = None

    def _create_consumer(self):
        return Consumer({
            'bootstrap.servers': settings.KAFKA_BROKER,
            'group.id': 'fraud-detection-group',
            'auto.offset.reset': 'latest',
            'enable.auto.commit': True,
        })

    def _create_producer(self):
        return Producer({
            'bootstrap.servers': settings.KAFKA_BROKER,
        })

    def process_message(self, msg):
        try:
            data = json.loads(msg.value().decode('utf-8'))
            transaction = Transaction(**data)
            prediction = model_service.predict(transaction)

            logger.info(
                "stream_prediction",
                transaction_id=transaction.transaction_id,
                is_fraud=prediction.is_fraud,
                probability=prediction.fraud_probability
            )

            if prediction.is_fraud:
                from datetime import datetime
                alert = {
                    "alert_id": f"alert_{transaction.transaction_id}",
                    "transaction_id": transaction.transaction_id,
                    "user_id": transaction.user_id,
                    "fraud_probability": prediction.fraud_probability,
                    "risk_level": prediction.risk_level,
                    "timestamp": str(datetime.utcnow()),
                }
                self.producer.produce(
                    settings.KAFKA_TOPIC_FRAUD_ALERTS,
                    json.dumps(alert).encode('utf-8')
                )
                self.producer.flush()

        except Exception as e:
            logger.error("stream_processing_error", error=str(e))

    def run(self):
        self.consumer = self._create_consumer()
        self.producer = self._create_producer()
        self.consumer.subscribe([settings.KAFKA_TOPIC_TRANSACTIONS])
        logger.info("stream_processor_started", topic=settings.KAFKA_TOPIC_TRANSACTIONS)

        try:
            while True:
                msg = self.consumer.poll(timeout=1.0)
                if msg is None:
                    continue
                if msg.error():
                    if msg.error().code() == KafkaError._PARTITION_EOF:
                        continue
                    else:
                        logger.error("kafka_error", error=msg.error())
                        break
                self.process_message(msg)
        except KeyboardInterrupt:
            logger.info("stream_processor_stopped")
        finally:
            self.consumer.close()


if __name__ == "__main__":
    processor = FraudStreamProcessor()
    processor.run()
